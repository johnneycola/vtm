# ==========================================
# n1_r200_2 — "Что у вас случилось?"
# Внутри — вложенные разветвления n1_r201 и n1_r202
# ==========================================

label n1_r200_2:

    d "Прости, не стоило так говорить. Расскажи, что у вас случилось?"
    "Она хихикнула."
    c "Вообще, это я ему изменила. Но он, конечно, козёл. Иначе я бы этого не сделала."
    d "Ты намеренно изменила ему?"
# Дамьен — Клэр
    hide bg
    hide damien front
    hide claire back
    pause char_transition_pause
    show bg bar_inside at bg_pos
    show claire front at claire_front_pos
    show damien back at damien_back_pos
    c "Слушай, как тебе сказать... я из Ирики, он из Остина. Он прикатил сюда на Тесле и покорил меня..."

    menu:
        "Пропустить мимо ушей...":
            jump n1_r201_1

        "Слушать дальше...":
            jump n1_r201_2


# ------------------------------------------
# n1_r201_1 — уходит на общий текст парковки
# (совпадает с n1_r200_3, см. этот файл)
# ------------------------------------------
label n1_r201_1:

    jump n1_r200_3


# ------------------------------------------
# n1_r201_2 — "Слушать дальше..."
# ------------------------------------------
label n1_r201_2:

    $ heard_claire_full_story = True
    d "Ого!"
    c "Ага! Стоял, курил, ждал пока машина зарядится."
    c "Я стрельнула у него сигарету, он предложил прокатиться. В общем, слово за слово и я уже с ним на заднем сиденье."
    think "Не надо. Не улыбайся."
    c "Короче, он рассказывал, что у него там какой-то стартап, что-то про нейросети и удобрения. Типа он изобрёл какую-то бактерию, которая что-то там делает с навозом... ладно, не буду делать вид, что я что-то поняла."
    "Она снова хихикнула."
    c "Я подумала: «ну, звучит, как много денег». Трахался он, конечно, так себе..."
    think "А вот теперь можно и улыбнуться."
    c "Короче, я поехала к нему в Остин и, знаешь что? Тесла была самым дорогим, что у него было!"
    c "«Ну, ладно,» — подумала я, — «дай парню шанс». Но это был просто какой-то кошмар."
    d "В каком смысле?"
    c "Этот хрен не мог даже яичницу себе пожарить! Серьёзно, у него все ящики были забиты блядскими кукурузными хлопьями!"
    c "Фу, мне аж противно вспоминать. Ещё эта вонища была повсюду от его удобрений. Мне кажется у меня до сих пор волосы пахнут..."
    "Она нюхает прядь волос и затем протягивает её мне."

    menu:
        "Отказаться.":
            jump n1_r202_1

        "Понюхать. [difficulty_note('сложность питания: -1')]":
            jump n1_r202_2


# ------------------------------------------
# n1_r202_1 — "Отказаться." (своего текста нет,
# сразу уходит на точку схождения)
# ------------------------------------------
label n1_r202_1:

    jump n1_r202_join


# ------------------------------------------
# n1_r202_2 — "Понюхать."
# ------------------------------------------
label n1_r202_2:

    $ feeding_difficulty = 1
    think "Не напрягайся. Сделай вид, что вдыхаешь. Она не заметит."
# Клэр — Дамьен
    hide bg
    hide claire front
    hide damien back
    pause char_transition_pause
    show bg bar_scene at bg_pos
    show damien front at damien_front_pos
    show claire back at claire_back_pos
    d "Пахнет шампунем."
# Дамьен — Клэр
    hide bg
    hide damien front
    hide claire back
    pause char_transition_pause
    show bg bar_inside at bg_pos
    show claire front at claire_front_pos
    show damien back at damien_back_pos
    c "Серьёзно?"
    "Она нюхает прядь ещё раз, пожимает плечами и продолжает."
    c "Странно, я вообще вчера голову мыла, до сих пор держится что ли?"
    c "Короче, у меня теперь ПТСР! Я не могу есть хлопья, мне от каждой коробки воняет коровьим говном!"

    jump n1_r202_join


# ------------------------------------------
# Точка схождения n1_r202_1 и n1_r202_2
# ------------------------------------------
label n1_r202_join:

# Клэр — Дамьен
    hide bg
    hide claire front
    hide damien back
    pause char_transition_pause
    show bg bar_scene at bg_pos
    show damien front at damien_front_pos
    show claire back at claire_back_pos
    d "Понятно почему ты изменила ему. Быть мамашей ты не нанималась."
# Дамьен — Клэр
    hide bg
    hide damien front
    hide claire back
    pause char_transition_pause
    show bg bar_inside at bg_pos
    show claire front at claire_front_pos
    show damien back at damien_back_pos
    c "Да! Ну и я просто от обиды пошла накидалась в баре и отсосала какому-то фермеру..."
    c "Которого видимо не очень парило, что от девушки воняет навозом."
    c "Ох... как рассказываю, снова аж злость берёт. Не хочешь выйти покурить?"
    "Она хватает со стойки пачку сигарет и зажигалку, кивая мне на выход и приглашает пойти за ней. Мы выходим из бара на парковку."
# Клэр уходит    
    show claire front at claire_front_leave
    hide claire front
    think "Приятного аппетита."
    hide bg
# Дамьен уходит    
    show damien back at damien_back_leave
    hide damien back
    play sfx "audio/sfx/doorbell.ogg"
    pause char_transition_pause

    jump n1_r200_join
